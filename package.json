{
  "name": "easyfinder",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean.ps1",
    "openapi:validate": "swagger-cli validate ./openapi.yml",
    "openapi:types": "openapi-typescript ./openapi.yml -o ./apps/web/src/generated/openapi.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.1",
    "only-allow": "^1.2.1",
    "openapi-typescript": "7.6.1",
    "prettier": "^3.8.1",
    "swagger-cli": "4.0.4",
    "turbo": "^2.7.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "papaparse": "^5.5.3"
  }
}
